# Copy to docker/.env and fill in.
# `docker compose` auto-loads docker/.env when run from the docker/ folder, or
# pass with --env-file. NEVER commit the populated file.

# ─── Image / network ─────────────────────────────────────────────────────────
# Docker Hub is the default image. Set IMAGE=ghcr.io/tilianb/hidemyemail to use GHCR.
# IMAGE=docker.io/tilianb/hidemyemail

# Pin a specific release here, otherwise the compose file defaults to :latest.
# Docker Hub publishes release tags only: latest, vX.Y.Z, vX.Y, vX.
# GHCR also publishes main and sha-<short> tags.
# IMAGE_TAG=v1.2.3

# Default is "missing" (only pull if not present locally). Set to "always" to
# force a pull on every `up`, or "never" if you build from source.
# PULL_POLICY=missing

# Host port the container's 8787 maps to. Put a reverse proxy (Caddy/nginx) in
# front for TLS in production.
# HOST_PORT=8787

# Comma-separated exact socket peer IPs allowed to set
# X-HideMyEmail-Client-IP. Leave empty for direct loopback-only access. If a
# reverse proxy is used, list only its address and configure it to OVERWRITE
# (never append/forward) that header with the connecting client's IP.
# TRUSTED_PROXY_IPS=127.0.0.1,::1

# ─── Worker runtime ───────────────────────────────────────────────────────────
# Defaults to self-hosted.
# ENVIRONMENT=self-hosted
# Required canonical public dashboard origin. Use the externally visible HTTPS
# origin only: no path, query, fragment, credentials, or trailing slash. HTTP is
# accepted only for localhost development. Passkeys will be bound to this value.
APP_ORIGIN=https://app.example.com
# Bump only if you also rebuild against a newer Miniflare/workerd.
# COMPATIBILITY_DATE=2026-05-01

# ─── AWS SES / S3 / SNS ───────────────────────────────────────────────────────
# Self-hosting the Worker still leaves the mail pipeline on AWS. You need:
#   - SES domain identity + DKIM verified
#   - Receipt rule that stores raw MIME in S3_INBOUND_BUCKET
#   - SNS topic with HTTPS subscription pointing at https://your-host/api/ses/inbound
#   - IAM keypair with ses:SendRawEmail + s3:GetObject on the bucket
SES_REGION=ap-southeast-2
S3_INBOUND_BUCKET=hidemyemail-inbound-raw
SES_ACCESS_KEY_ID=AKIA...
SES_SECRET_ACCESS_KEY=...

# SNS topic ARNs — used for verifying the source of incoming webhooks. Leave
# blank to disable that check (NOT recommended in production).
SNS_INBOUND_TOPIC_ARN=arn:aws:sns:ap-southeast-2:000000000000:hidemyemail-inbound
SNS_ALLOWED_TOPIC_ARN=arn:aws:sns:ap-southeast-2:000000000000:hidemyemail-outbound

# ─── iOS push notifications (optional) ────────────────────────────────────────
# APNs token-based auth for the iOS app. Leave blank to disable push (device
# registration still works; nothing is sent). APNS_TEAM_ID / APNS_BUNDLE_ID are
# derived from APPLE_APP_ID ("<TeamID>.<bundleId>") when left unset.
# APPLE_APP_ID=ABCDE12345.dev.hidemyemail.app
# APNS_KEY_ID=ABCD123456
# APNS_TEAM_ID=
# APNS_BUNDLE_ID=
# Use api.sandbox.push.apple.com for development-signed builds.
# APNS_HOST=
# Contents of the AuthKey_XXXXXXXXXX.p8 (full PEM). Treat as a secret.
# APNS_AUTH_KEY=

# ─── Android push notifications (optional) ────────────────────────────────────
# FCM HTTP v1 for the Android app. Leave blank to disable Android push (device
# registration still works; nothing is sent). Full Firebase service-account
# JSON on one line; treat as a secret. FCM_PROJECT_ID defaults to its project_id.
# FCM_PROJECT_ID=
# FCM_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}

# ─── App secrets ──────────────────────────────────────────────────────────────
# Generate fresh values per install:
#   SESSION_SECRET=$(openssl rand -hex 32)
#   DESTINATION_ENCRYPTION_KEY=$(openssl rand -base64 32)   # base64, NOT hex — AES needs exactly 32 bytes
#   AUTH_PASSWORD_SALT=$(openssl rand -hex 16)
#   AUTH_PASSWORD_HASH=$(node worker/scripts/hash-password.mjs <password> <salt>)
SESSION_SECRET=
AUTH_PASSWORD_HASH=
AUTH_PASSWORD_SALT=
DESTINATION_ENCRYPTION_KEY=
# Signs one-click unsubscribe links (optional — falls back to SESSION_SECRET;
# set it separately so rotating sessions doesn't invalidate unsubscribe links)
# ACTION_SECRET=
