# Copy to worker/.dev.vars for local development. Never commit .dev.vars.
ENVIRONMENT=local
SES_REGION=ap-southeast-2
S3_INBOUND_BUCKET=your-ses-inbound-raw-bucket
SNS_ALLOWED_TOPIC_ARN=arn:aws:sns:ap-southeast-2:123456789012:your-outbound-topic
SNS_INBOUND_TOPIC_ARN=arn:aws:sns:ap-southeast-2:123456789012:your-inbound-topic
SES_ACCESS_KEY_ID=replace-with-aws-access-key-id
SES_SECRET_ACCESS_KEY=replace-with-aws-secret-access-key
SESSION_SECRET=replace-with-openssl-rand-hex-32
ACTION_SECRET=replace-with-openssl-rand-hex-32
AUTH_PASSWORD_SALT=replace-with-worker-scripts-hash-password-output
AUTH_PASSWORD_HASH=replace-with-worker-scripts-hash-password-output
DESTINATION_ENCRYPTION_KEY=replace-with-32-byte-hex-key

# iOS push notifications (optional — push is a no-op when unset).
# APNS_TEAM_ID / APNS_BUNDLE_ID are derived from APPLE_APP_ID when omitted.
# APNS_HOST: api.sandbox.push.apple.com for Xcode/dev-signed builds (local dev),
#            api.push.apple.com for TestFlight / App Store (production).
APNS_KEY_ID=replace-with-10-char-apns-key-id
APNS_AUTH_KEY=replace-with-contents-of-AuthKey_XXXXXXXXXX.p8
APNS_HOST=api.sandbox.push.apple.com
