{
  "name": "hidemyemail-worker",
  "version": "1.0.0",
  "description": "Cloudflare Worker for HideMyEmail alias service",
  "author": "Tilian Burger",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "wrangler deploy --env=\"\" --keep-vars",
    "deploy:preview": "wrangler deploy --env preview --keep-vars",
    "migrate:prod": "wrangler d1 migrations apply DB --remote --env=\"\"",
    "migrate:preview": "wrangler d1 migrations apply DB --remote --env preview",
    "predeploy:preview": "npm run migrate:preview",
    "typegen": "wrangler types"
  },
  "dependencies": {
    "@simplewebauthn/server": "^13.3.1",
    "aws4fetch": "^1.0.20",
    "hono": "^4.12.27",
    "mimetext": "^3.0.28",
    "postal-mime": "^2.7.4"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.18",
    "@cloudflare/workers-types": "^4.20260616.1",
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.98.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
