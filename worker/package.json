{
  "name": "hidemyemail-worker",
  "version": "1.0.0",
  "description": "Cloudflare Worker for HideMyEmail alias service",
  "author": "Tilian Burger",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "wrangler deploy --env=\"\"",
    "deploy:preview": "wrangler deploy --env preview",
    "migrate:prod": "wrangler d1 migrations apply DB --remote --env=\"\"",
    "migrate:preview": "wrangler d1 migrations apply DB --remote --env preview",
    "predeploy:preview": "npm run migrate:preview",
    "typegen": "wrangler types"
  },
  "dependencies": {
    "aws4fetch": "^1.0.20",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.9",
    "@cloudflare/workers-types": "^4.20260526.1",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.94.0"
  }
}
