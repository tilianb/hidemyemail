<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- allowBackup=false: SharedPreferences hold the bearer session token,
         and Auto Backup would otherwise copy it into cloud backups and
         device-to-device transfers. Mirrors the iOS ThisDeviceOnly keychain
         stance; everything else the app stores is refetchable from the server. -->
    <application
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:allowBackup="false"
        android:supportsRtl="true"
        android:theme="@style/Theme.HideMyEmail">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.HideMyEmail">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Web-session login handoff: the dashboard redirects to
                 hidemyemail://auth?code=… after a successful sign-in. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="hidemyemail" android:host="auth" />
            </intent-filter>
        </activity>
    </application>
</manifest>
