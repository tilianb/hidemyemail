<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Android 13+ requires runtime consent to post notifications; requested
         from the Settings ▸ Notifications toggle. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Keep encrypted credential metadata out of Auto Backup and device-to-
         device transfers. The encryption key is non-exportable in Android
         Keystore; everything else is refetchable from the server. -->
    <application
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:allowBackup="false"
        android:supportsRtl="true"
        android:theme="@style/Theme.HideMyEmail">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.HideMyEmail">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Web-session login handoff: the dashboard redirects to
                 hidemyemail://auth?code=… after a successful sign-in. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="hidemyemail" android:host="auth" />
            </intent-filter>
        </activity>

        <!-- FCM token rotations land here; notification payloads are rendered by
             the FCM SDK into the channel below. -->
        <service
            android:name=".push.PushMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="@string/push_channel_id" />
    </application>
</manifest>
