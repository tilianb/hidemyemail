{
  "compilerOptions": {
    "target": "ES2020", "useDefineForClassFields": true, "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext", "moduleResolution": "bundler", "jsx": "react-jsx",
    "noEmit": true, "strict": true, "noUnusedLocals": true, "skipLibCheck": true
  },
  "include": ["src"]
}
